{
  "name": "slidegen",
  "version": "0.1.0",
  "description": "Template-driven slide generator. Maps title/images/body into a fixed template and renders directly to Google Slides.",
  "type": "module",
  "bin": {
    "slidegen": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "slidegen": "tsx src/index.ts",
    "make:bg": "tsx scripts/make-placeholder-bg.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "googleapis": "^144.0.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
