# Copy this file to .env and fill in the values you obtain by following docs/api-setup.md.
# NEVER commit the real .env (it is git-ignored).

# --- Google OAuth2 (個人利用 / installed-app flow) ---
# Google Cloud Console > APIs & Services > Credentials で発行した
# 「OAuth client ID (Desktop app)」の値を入れる。
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# OAuth リダイレクト先。loopback (installed-app) なら下記のままで良い。
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/oauth2callback

# OAuth トークンの保存先。.gitignore 済み。
GOOGLE_TOKEN_PATH=token.json

# 透視変換に使う Python 実行ファイル（省略時は "python"）。
# 例: Windows なら "py" / venv なら ".venv/Scripts/python.exe"
PYTHON_BIN=python

# --- HTTP API (Phase 2: src/server.ts) ---
# GAS など外部から /render を叩く際の共有シークレット。
# GAS の Script Properties RENDER_API_KEY と同じ値にする。十分長いランダム文字列を自分で生成して入れる。
# 例の生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RENDER_API_KEY=

# API の待受ポート（Cloud Run は PORT を注入するので未設定で可。ローカル既定 8080）。
PORT=8080
