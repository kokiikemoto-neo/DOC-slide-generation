{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "stylespec.schema.json",
  "title": "StyleSpec",
  "type": "object",
  "required": ["version", "pageSize", "palette", "typography", "editableSlots", "regions"],
  "properties": {
    "version": { "type": "string" },
    "pageSize": {
      "type": "object",
      "required": ["w", "h"],
      "properties": { "w": { "type": "number" }, "h": { "type": "number" } }
    },
    "background": { "type": "string" },
    "palette": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
    },
    "typography": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["family", "sizePt", "color"],
        "properties": {
          "family": { "type": "string" },
          "fontCandidates": { "type": "array", "items": { "type": "string" } },
          "weightHint": { "enum": ["regular", "medium", "bold"] },
          "sizePt": { "type": "number" },
          "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
          "align": { "enum": ["left", "center", "right"] }
        }
      }
    },
    "editableSlots": { "type": "array", "items": { "type": "string" } },
    "regions": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "role", "rect"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "rect" },
              "role": { "enum": ["image", "text"] },
              "fit": { "enum": ["contain", "cover"] },
              "style": { "type": "string" },
              "note": { "type": "string" },
              "rect": {
                "type": "object",
                "required": ["x", "y", "w", "h"],
                "properties": {
                  "x": { "type": "number" }, "y": { "type": "number" },
                  "w": { "type": "number" }, "h": { "type": "number" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "role", "fit", "quad"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "quad" },
              "role": { "const": "image" },
              "fit": { "const": "perspective" },
              "note": { "type": "string" },
              "quad": {
                "type": "object",
                "required": ["tl", "tr", "br", "bl"],
                "additionalProperties": false,
                "properties": {
                  "tl": { "$ref": "#/definitions/point" },
                  "tr": { "$ref": "#/definitions/point" },
                  "br": { "$ref": "#/definitions/point" },
                  "bl": { "$ref": "#/definitions/point" }
                }
              }
            }
          }
        ]
      }
    },
    "notes": { "type": "object", "additionalProperties": { "type": "string" } }
  },
  "definitions": {
    "point": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
    }
  }
}
