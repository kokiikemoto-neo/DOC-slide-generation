{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "slideplan.schema.json",
  "title": "SlidePlan",
  "type": "object",
  "required": ["styleRef", "slides"],
  "properties": {
    "styleRef": { "type": "string" },
    "slides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["elements"],
        "properties": {
          "elements": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["region", "type"],
              "properties": {
                "region": { "type": "string" },
                "type": { "enum": ["text", "image", "shape"] },
                "value": { "type": "string" },
                "fit": { "enum": ["cover", "contain", "perspective"] },
                "fontSizePt": { "type": "number" }
              }
            }
          },
          "overflow": {
            "type": "object",
            "additionalProperties": { "enum": ["fit", "trimmed", "split"] }
          }
        }
      }
    }
  }
}
